ID=1
DEV=false

# Path to JSON config file (overrides env vars if set)
CONFIG_FILE=

# Location of the pre-signed certificate
PRESIGNED_CERT=/opt/storage/key.pem
TRANSLATION_DIRECTORY=/usr/share/webitel/engine/i18n
AUTH_CACHE_EXPIRE=30

# Public hostname
PUBLIC_HOST=

# WebRTC configuration (JSON)
RTC_CONFIGURATION=

# Maximum member communications
MAX_MEMBER_COMMUNICATIONS=20

# Log level (debug|info|warn|error)
LOG_LVL=debug
LOG_JSON=false
LOG_OTEL=false
LOG_CONSOLE=false
LOG_FILE=

# Consul host
CONSUL=172.0.0.1:8500
AMQP=amqp://admin:admin@rabbit:5672?heartbeat=10

DATA_SOURCE=postgres://postgres:postgres@postgres:5432/webitel?fallback_application_name=engine&sslmode=disable&connect_timeout=10&search_path=call_center
SQL_DATA_SOURCE_REPLICAS=

SQL_MAX_IDLE_CONNS=5
SQL_MAX_OPEN_CONNS=5
SQL_LIFETIME_MILLISECONDS=300000
SQL_TRACE=false
SQL_LOG=false
QUERY_TIMEOUT=10

GRPC_ADDR=

# gRPC port (0 = random/auto)
GRPC_PORT=0

# Maximum gRPC message size
GRPC_MAX_MESSAGE_SIZE=16MB

WEBSOCKET=:80

# Maximum inbound WebSocket message size
SOCKET_MAX_IN_MSG_SIZE=256KB

OPEN_SIP_ADDR=opensips
WS_SIP_ADDR=
SIP_PROXY_ADDR=

# Client ping interval (0 = disabled)
PING_CLIENT_INTERVAL=0
PING_CLIENT_LATENCY=0

MIN_NUMBER_MASK_LEN=0
PREFIX_NUMBER_MASK_LEN=5
SUFFIX_NUMBER_MASK_LEN=5

PUSH_FIREBASE=
PUSH_APN_HOST=
PUSH_APN_CERT_FILE=
PUSH_APN_KEY_FILE=
PUSH_APN_TOPIC=com.webitel.webitel-ios.voip

TRIGGER_ENABLED=true
TRIGGER_BROKER_URL=
TRIGGERS_EXCHANGE=cases
TRIGGERS_QUEUE=engine.trigger
